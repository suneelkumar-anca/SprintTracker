# ─── Copy this file to .env and fill in your values ───────────────────────────

# ── Jira Cloud (REQUIRED) ───────────────────────────────────────────────────────
# Your Atlassian domain (no trailing slash)
VITE_JIRA_BASE_URL=https://yourcompany.atlassian.net/

# Your Atlassian account email
VITE_JIRA_EMAIL=your@email.com

# API token — create at: https://id.atlassian.com/manage-profile/security/api-tokens
VITE_JIRA_API_TOKEN=

# ── Jira Sprint Browse (OPTIONAL) ──────────────────────────────────────────────
# Jira project key (e.g. TR, PROJ) — used to list sprint tickets in the side panel
VITE_JIRA_PROJECT_KEY=

# Specific sprint ID (numeric) — if omitted, uses openSprints() JQL
VITE_JIRA_SPRINT_ID=

# ── Custom Jira Fields (OPTIONAL) ──────────────────────────────────────────────
# Configure these if your Jira project uses custom fields for TL data.
# Find field IDs at: https://yourcompany.atlassian.net/rest/api/3/field

# Custom field ID for TL Comment (default: customfield_10100)
VITE_JIRA_FIELD_TL_COMMENT=customfield_10100

# Custom field ID for Review Rating 1-5 (default: customfield_10101)
VITE_JIRA_FIELD_REVIEW_RATING=customfield_10101

# Custom field ID for Artifacts (default: customfield_10102)
VITE_JIRA_FIELD_ARTIFACTS=customfield_10102

# ── Confluence Cloud (OPTIONAL) ──────────────────────────────────────────────
# Enables "Publish to Confluence" button to export sprint data as wiki pages.

# Your Atlassian domain (no trailing slash) — must match Jira domain
VITE_CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net

# Your Atlassian account email (same as Jira)
VITE_CONFLUENCE_EMAIL=your@email.com

# API token (same as Jira) — create at: https://id.atlassian.com/manage-profile/security/api-tokens
VITE_CONFLUENCE_API_TOKEN=

# Confluence space key (found in space URL: /spaces/{KEY}) — your space: ~71202050afb4eb453943889b7f6592c7305cc1
VITE_CONFLUENCE_SPACE_KEY=

# Parent page ID — if set, sprint reports created under this page; if omitted, auto-creates "Sprint Reports" parent
VITE_CONFLUENCE_PARENT_PAGE_ID=

# ── Sprint Retrospectives (OPTIONAL) ─────────────────────────────────────────
# Fine-grained PAT with "Models" account permission (Read-only)
# Get: https://github.com/settings/personal-access-tokens/new
# Account permissions → Models: Read-only  (NOT "Copilot Requests")
# Leave blank to use heuristic analysis only
VITE_GITHUB_TOKEN=
